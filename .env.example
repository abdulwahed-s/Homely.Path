# Firebase project used by the trusted FastAPI backend.
FIREBASE_PROJECT_ID=homelypath

# Local development only. Prefer Application Default Credentials on Google-hosted
# deployments such as Cloud Run. Never expose this file or value to the frontend.
GOOGLE_APPLICATION_CREDENTIALS=C:/absolute/path/firebase-service-account.json

# Render or another non-Google host. Store the complete service-account JSON as
# one secret environment-variable value. Configuring Firebase credentials also
# enables ID-token enforcement for /internal/ai/*; /api/discovery remains public.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Local emulator only:
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080

# Comma-separated frontend origins for production.
REALDOOR_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Deterministic rules chat. No external model or API key is used.
CHATBOT_ENABLED=true
CHATBOT_MAX_QUESTION_LENGTH=500
CHAT_SESSION_COLLECTION=chat_sessions
REALDOOR_PACK_ROOT=./organizer_pack

# Optional AI extraction configuration.
OPENAI_API_KEY=
